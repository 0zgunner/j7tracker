# Ethereum wallet tracking
ETHERSCAN_API_KEY=your_etherscan_key_here

# Robinhood Chain wallet tracking (Blockscout explorer, no key required,
# but you can set a custom RPC provider key if you upgrade off the public endpoint)
ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com

# Solana wallet tracking - Helius free tier
HELIUS_API_KEY=your_helius_key_here

# Reddit trend tracking - requires a free "script" app from reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=J7Tracker/1.0 (by /u/your_reddit_username)

# News tracking (CoinDesk + Cointelegraph RSS) - no key required at all
